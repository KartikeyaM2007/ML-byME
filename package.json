{
  "name": "tensortonic",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "scrape:api": "node scraper/scrape_tensortonic_api.js",
    "scrape:merge": "node scraper/merge_api_data.js",
    "scrape": "npm run scrape:api && npm run scrape:merge",
    "scrape:site": "node scraper/scrape_site_data.js",
    "fetch:data": "node scraper/fetch_all_data.js",
    "fetch:research-problems": "node scraper/scrape_research_problems.js",
    "fetch:enrich-details": "node scraper/enrich_problem_details.js",
    "fetch:enrich-all": "node scraper/build_study_plan_sections.js && node scraper/build_math_content.js && node scraper/enrich_theory_solution.js",
    "scrape:research-cdp": "node scraper/scrape_research_problems.js --cdp",
    "fetch:rebuild-list": "node scraper/rebuild_problem_list.js",
    "fetch:all": "node scraper/merge_all_problems.js",
    "test:smoke": "node scraper/smoke_test.js",
    "test:data": "node scraper/verify_data.js",
    "test:features": "node scraper/feature_test.js",
    "test:backend": "node scraper/test_backend.js",
    "test:run-submit": "node scraper/test_run_submit.js",
    "test:all": "node scraper/verify_data.js && npm run build && npm run test:smoke && npm run test:features && npm run test:backend",
    "setup:content": "npm run fetch:enrich-all && npm run fetch:research-problems",
    "scrape:frontend": "cd tensortonic-scrape && npm run scrape",
    "scrape:frontend:grep": "cd tensortonic-scrape && npm run grep",
    "backend": "node backend/server.js",
    "start": "npm run build && node scripts/start-production.cjs",
    "start:api": "node scripts/start-production.cjs",
    "docker:build": "docker build -t tensortonic .",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "screenshots:readme": "node scripts/capture-readme-screenshots.mjs"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "playwright": "^1.60.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "katex": "^0.17.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "three": "^0.184.0"
  }
}
